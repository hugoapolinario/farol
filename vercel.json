{
  "buildCommand": "node backend/build.js",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://js.hcaptcha.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; media-src 'self' blob:; connect-src 'self' https://*.supabase.co https://api.resend.com https://buy.polar.sh; frame-src https://js.hcaptcha.com; object-src 'none'; base-uri 'self';"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/frontend/landing/index.html" },
    { "source": "/index.html", "destination": "/frontend/landing/index.html" },
    { "source": "/signup.html", "destination": "/frontend/auth/signup.html" },
    { "source": "/login.html", "destination": "/frontend/auth/login.html" },
    { "source": "/reset.html", "destination": "/frontend/auth/reset.html" },
    { "source": "/update-password.html", "destination": "/frontend/auth/update-password.html" },
    { "source": "/confirmed.html", "destination": "/frontend/auth/confirmed.html" },
    { "source": "/app.html", "destination": "/frontend/app/app.html" },
    { "source": "/settings.html", "destination": "/frontend/app/settings.html" },
    { "source": "/share.html", "destination": "/frontend/app/share.html" },
    { "source": "/dashboard.html", "destination": "/frontend/app/dashboard.html" },
    { "source": "/docs.html", "destination": "/frontend/docs/docs.html" },
    { "source": "/demo.html", "destination": "/frontend/app/demo.html" },
    { "source": "/privacy.html", "destination": "/frontend/legal/privacy.html" },
    { "source": "/terms.html", "destination": "/frontend/legal/terms.html" },
    { "source": "/signup", "destination": "/frontend/auth/signup.html" },
    { "source": "/login", "destination": "/frontend/auth/login.html" },
    { "source": "/reset", "destination": "/frontend/auth/reset.html" },
    { "source": "/app", "destination": "/frontend/app/app.html" },
    { "source": "/settings", "destination": "/frontend/app/settings.html" },
    { "source": "/share", "destination": "/frontend/app/share.html" },
    { "source": "/docs", "destination": "/frontend/docs/docs.html" },
    { "source": "/demo", "destination": "/frontend/app/demo.html" },
    { "source": "/privacy", "destination": "/frontend/legal/privacy.html" },
    { "source": "/terms", "destination": "/frontend/legal/terms.html" },
    { "source": "/feedback", "destination": "/frontend/feedback/index.html" },
    { "source": "/changelog", "destination": "/frontend/changelog/index.html" },
    { "source": "/security", "destination": "/frontend/security/index.html" },
    { "source": "/update-password", "destination": "/frontend/auth/update-password.html" },
    { "source": "/confirmed", "destination": "/frontend/auth/confirmed.html" }
  ]
}
